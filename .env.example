# Edinburgh Whispers Route - Environment Variables Template
# Copy this to .env.local for local development

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AI API KEYS
# =============================================================================

# OpenAI API Key (required for tour content generation)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# ElevenLabs API Key (optional, for audio generation)
# Get from: https://elevenlabs.io/
# Note: App works without this, uses fallback
ELEVENLABS_API_KEY=...

# =============================================================================
# ANALYTICS (PostHog)
# =============================================================================
# Get from: https://us.posthog.com/settings/project-api-key
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# SUPABASE EDGE FUNCTIONS (Server-side only)
# =============================================================================
# These are set via: supabase secrets set KEY=value
# Do NOT add VITE_ prefix to these!

# Required for Edge Functions:
# - OPENAI_API_KEY (same as above, set via CLI)
# - ELEVENLABS_API_KEY (optional, set via CLI)

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
#
# [ ] Set VITE_SUPABASE_URL in Lovable
# [ ] Set VITE_SUPABASE_ANON_KEY in Lovable
# [ ] Set VITE_OPENAI_API_KEY in Lovable
# [ ] Run: supabase secrets set OPENAI_API_KEY=sk-...
# [ ] Run: supabase secrets set ELEVENLABS_API_KEY=... (optional)
# [ ] Deploy all Edge Functions
# [ ] Test tour generation
#
# =============================================================================
